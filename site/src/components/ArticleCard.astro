---
import type { CollectionEntry } from "astro:content";
import TagBadge from "./TagBadge.astro";

interface Props {
  article: CollectionEntry<"articles">;
  index?: number;
  variant?: "default" | "lead" | "compact";
}
const { article, index, variant = "default" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = `${base}/articles/${article.id}`;
const dateStr = article.data.pubDate.toISOString().slice(0, 10);
---

<article class={`card card-${variant}`} data-pagefind-ignore="all">
  {variant === "lead" ? (
    <header>
      <div class="meta-top">
        {index !== undefined && <span class="num">{String(index).padStart(2, "0")}</span>}
        <span class="src">{article.data.sourceName}</span>
        <span class="dot-sep">·</span>
        <time>{dateStr}</time>
      </div>
      <h2 class="title">
        <a href={href}>{article.data.title}</a>
      </h2>
      <p class="orig">{article.data.titleOriginal}</p>
      <p class="desc">{article.data.description}</p>
      <div class="tags">
        {article.data.tags.map((t: string) => <TagBadge slug={t} />)}
      </div>
    </header>
  ) : (
    <>
      <div class="meta-top">
        {index !== undefined && <span class="num">{String(index).padStart(2, "0")}</span>}
        <span class="src">{article.data.sourceName}</span>
        <span class="dot-sep">·</span>
        <time>{dateStr}</time>
      </div>
      <h3 class="title">
        <a href={href}>{article.data.title}</a>
      </h3>
      <p class="desc">{article.data.description}</p>
      <div class="tags">
        {article.data.tags.map((t: string) => <TagBadge slug={t} />)}
      </div>
    </>
  )}
</article>

<style>
  .card { padding: 22px 0; border-bottom: 1px solid var(--border); }
  .card:last-child { border-bottom: none; }
  .card-lead {
    padding: 0 0 28px;
    margin-bottom: 16px;
    border-bottom: 2px solid var(--text);
  }
  .meta-top {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--text-muted);
    font-size: 0.78rem;
    font-family: var(--font-sans);
    letter-spacing: 0.02em;
    margin-bottom: 8px;
  }
  .num {
    font-family: var(--font-mono);
    color: var(--accent);
    font-weight: 700;
    font-size: 0.78rem;
  }
  .src { font-weight: 500; }
  .dot-sep { color: var(--text-dim); }
  time { font-family: var(--font-mono); }

  .title {
    font-family: var(--font-serif);
    margin: 0 0 6px;
    line-height: 1.3;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .card-default .title { font-size: 1.18rem; }
  .card-lead .title { font-size: 1.7rem; }
  .card-compact .title { font-size: 1rem; }

  .title a {
    color: var(--text);
    border-bottom: 0;
    background-image: linear-gradient(var(--accent), var(--accent));
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0% 1px;
    transition: background-size 0.25s ease;
  }
  .title a:hover {
    color: var(--accent);
    background-size: 100% 1px;
    border-bottom: 0;
  }

  .orig {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--text-muted);
    font-size: 0.95rem;
    margin: 0 0 10px;
  }
  .desc {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin: 0 0 12px;
  }
  .card-lead .desc { font-size: 1.05rem; color: var(--text); }
  .tags { display: flex; flex-wrap: wrap; gap: 0; }
</style>
