---
import { SITE_TITLE, SITE_TAGLINE } from "../consts";
import ThemeToggle from "./ThemeToggle.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const links = [
  { href: `${base}/`, label: "首页" },
  { href: `${base}/briefings`, label: "简报库" },
  { href: `${base}/archive`, label: "归档" },
  { href: `${base}/search`, label: "搜索" },
  { href: `${base}/about`, label: "关于" },
];
const year = new Date().getFullYear();
---

<header class="site-header">
  <div class="app-shell hdr-row">
    <div class="brand">
      <a href={`${base}/`}>
        <span class="brand-mark">AI</span>
        <span class="brand-text">
          <span class="brand-title">{SITE_TITLE}</span>
          <span class="brand-tagline">{SITE_TAGLINE} · {year}</span>
        </span>
      </a>
    </div>
    <nav>
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
    <div class="actions">
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .site-header {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 30;
    backdrop-filter: saturate(180%) blur(12px);
    background: color-mix(in srgb, var(--bg) 85%, transparent);
  }
  .hdr-row {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 16px 28px;
  }
  .brand a {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--text);
    border-bottom: 0;
  }
  .brand a:hover { border-bottom: 0; }
  .brand-mark {
    font-family: var(--font-sans);
    font-weight: 800;
    width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: white;
    border-radius: 8px;
    font-size: 0.95rem;
    letter-spacing: -0.02em;
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .brand-title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.08rem;
    letter-spacing: 0.01em;
  }
  .brand-tagline {
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.06em;
  }
  nav { display: flex; gap: 18px; margin-left: auto; }
  nav a {
    color: var(--text-muted);
    font-size: 0.92rem;
    border-bottom: 0;
    padding: 4px 2px;
    position: relative;
  }
  nav a:hover { color: var(--text); border-bottom: 0; }
  nav a:hover::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: -2px;
    height: 2px;
    background: var(--accent);
  }
  .actions { display: flex; align-items: center; gap: 8px; }
  @media (max-width: 720px) {
    .hdr-row { gap: 12px; padding: 12px 18px; flex-wrap: wrap; }
    .brand-tagline { display: none; }
    nav { gap: 12px; order: 3; flex-basis: 100%; justify-content: center; padding-top: 6px; border-top: 1px dashed var(--border); margin-top: 6px; }
    nav a { font-size: 0.86rem; }
  }
</style>
