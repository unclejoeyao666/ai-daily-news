---
import BaseLayout from "./BaseLayout.astro";
import AudioPlayer from "../components/AudioPlayer.astro";

interface Props {
  title: string;
  date: Date;
  audioUrl?: string;
}
const props = Astro.props;
const dateStr = props.date.toISOString().slice(0, 10);
const weekdays = ["日", "一", "二", "三", "四", "五", "六"];
const weekday = weekdays[props.date.getUTCDay()];
---

<BaseLayout
  title={props.title}
  description={`AI 科技每日早报 ${dateStr} 期`}
  highlightDate={dateStr}
>
  <header class="brf-head">
    <p class="eyebrow">每日简报</p>
    <h1>{props.title}</h1>
    <p class="brf-date">
      <time>{dateStr}</time> · 星期{weekday}
    </p>
    {props.audioUrl && <AudioPlayer src={props.audioUrl} date={dateStr} />}
  </header>
  <div class="brf-body">
    <slot />
  </div>
</BaseLayout>

<style>
  .brf-head {
    padding: 8px 0 4px;
    border-bottom: 2px solid var(--text);
    margin-bottom: 24px;
  }
  .brf-head h1 {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    margin: 4px 0 6px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }
  .brf-date {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin: 0 0 16px;
    font-family: var(--font-sans);
  }
  .brf-date time { font-family: var(--font-mono); }
  @media (max-width: 600px) {
    .brf-head h1 { font-size: 1.7rem; }
  }
</style>
