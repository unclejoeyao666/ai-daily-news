# Pipeline intermediate state (regenerated daily)
daily-selected.json

# v1 archive: keep .md tracked, ignore the heavy .mp3 / .wav files
archive/v1/**/*.mp3
archive/v1/**/*.wav
archive/v1/**/*.aac
archive/v1/**/*.m4a
